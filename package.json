  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "oxlint app components lib scripts --deny-warnings",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "mapapp": "node scripts/mapapp.mjs",
    "seed:runtime": "node scripts/seed-runtime.mjs",
    "smoke:runtime": "node scripts/smoke-runtime.mjs",
