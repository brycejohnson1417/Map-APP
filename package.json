    "check:tenant-types": "node scripts/check-tenant-type-docs.mjs",
    "check:self-contained-requirements": "node scripts/check-self-contained-requirements.mjs",
    "check:work-registry": "node scripts/check-work-registry.mjs",
    "verify:browser": "playwright test",
    "verify": "node scripts/verify.mjs",
    "review:adversarial": "node scripts/adversarial-review.mjs",
    "verify:full": "npm run verify && npm run review:adversarial"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "html2canvas": "^1.4.1",
    "leaflet": "^1.9.4",
