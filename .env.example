# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000

# Supabase runtime and migration access
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_ACCESS_TOKEN=replace-with-supabase-access-token
APP_ENCRYPTION_KEY=replace-with-long-random-string

# Clerk auth
CLERK_SECRET_KEY=replace-with-clerk-secret
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=replace-with-clerk-publishable-key

# Default local organization bootstrap
ORG_SLUG=picc
NEXT_PUBLIC_DEFAULT_ORG_SLUG=picc
ORG_NAME=PICC New York
NEXT_PUBLIC_ORG_NAME=PICC New York
OWNER_CLERK_ID=replace-with-owner-clerk-user-id
OWNER_EMAIL=owner@example.com
OWNER_NAME=Owner Name

# Legacy migration source
NEON_SOURCE_DATABASE_URL=postgresql://user:password@host/database

# Tenant connector credentials
NOTION_TOKEN=replace-with-notion-token
NOTION_WORKSPACE_ID=replace-with-notion-workspace-id
NOTION_DATA_SOURCE_IDS=[]
NOTION_COMPANIES_DATA_SOURCE_ID=replace-with-dispensary-master-list-crm-source-id
NOTION_CONTACTS_DATA_SOURCE_ID=replace-with-contacts-database-source-id
NOTION_WEBHOOK_VERIFICATION_TOKEN=replace-with-notion-webhook-verification-token
NABIS_API_BASE_URL=https://platform-api.nabis.pro/v2
NABIS_ORDERS_PATH=/ny/order
NABIS_API_KEY=replace-with-nabis-api-key

# Per-organization Google Maps credentials
GOOGLE_MAPS_BROWSER_API_KEY=replace-with-browser-key
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_API_KEY=replace-with-browser-key
GOOGLE_MAPS_SERVER_API_KEY=replace-with-server-key

# Optional deployment verification
VERCEL_PROJECT_ID=replace-with-vercel-project-id
VERCEL_TOKEN=replace-with-vercel-token
